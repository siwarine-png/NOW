EXPO_PUBLIC_ENGINE_URL=https://api.example.com
EXPO_PUBLIC_ENGINE_KEY=sk_live_your_key_here

# Google Cloud Console > APIs & Services > Credentials > Create OAuth client ID
# > Application type: Web application. Not actually used on Android (the
# library requires androidClientId there instead) — kept for a possible future
# web build, and as a fallback so the app doesn't crash before either is set.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Same Credentials page > Create OAuth client ID > Application type: Android
#   Package name: com.siwarin.e.nowapp (must match app.json's android.package)
#   SHA-1: from `eas credentials` after your first EAS development build
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
